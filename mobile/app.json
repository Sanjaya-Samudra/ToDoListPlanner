{
  "expo": {
    "name": "TaskFlow",
    "slug": "taskflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#6C63FF",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.taskflow.app"
    },
    "android": {
      "package": "com.taskflow.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#6C63FF"
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/notification-icon.png",
          "color": "#6C63FF"
        }
      ]
    ]
  }
}
